# VelocityIQ Environment Variables

# Clerk (required for Exit Snapshot download gate + Studio)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk URLs for Exit Snapshot
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/exit-snapshot/sign-in
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/exit-snapshot
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/exit-snapshot

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Resend (required for UK landing report email delivery)
RESEND_API_KEY=

# UK landing leads file (optional — defaults to data/uk-leads.jsonl in project root)
# UK_LEADS_FILE=C:\inetpub\wwwroot\Projects\BusinessAI.Frontend\velocityiq\data\uk-leads.jsonl

# US landing leads file (optional — defaults to data/us-leads.jsonl in project root)
# US_LEADS_FILE=

# Marcus Ellison sample report for email attachment (optional override)
# Default: public/usa-landing/USA_General_Main_Report.pdf
# US_SAMPLE_REPORT_PATH=public/usa-landing/USA_General_Main_Report.pdf
# US_LEAD_EMAIL_SUBJECT=
# US_LEAD_EMAIL_HTML=
